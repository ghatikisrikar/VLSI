`timescale 1ns / 1ps

module async_fifo #(
    parameter DATA_WIDTH = 8,   // data bus
    parameter ADDR_WIDTH = 4   // Depth 16 locations
) (
    input wire wclk,         // Write clock
    input wire wrst_n,       // Write domain active-low
    input wire wen,          // Write enable
    input wire [DATA_WIDTH-1:0] wdata,
    output wire wfull,       // Write domain full flag
    
    input wire rclk,         // Read clock
    input wire rrst_n,       // Read domain active-low
    input wire ren,          // Read enable
    output reg [DATA_WIDTH-1:0] rdata,
    output wire rempty       // Read domain empty flag
);

    // Memory 
    parameter DEPTH = 1 << ADDR_WIDTH;
    reg [DATA_WIDTH-1:0] mem [0:DEPTH-1];
    
   
    reg [ADDR_WIDTH:0] wptr_bin, wptr_gray;
    reg [ADDR_WIDTH:0] rptr_bin, rptr_gray;
    
    // 2-Stage Synchronizers to prevent metastability
    reg [ADDR_WIDTH:0] wq1_rptr, wq2_rptr; // Read to Write Sync
    reg [ADDR_WIDTH:0] rq1_wptr, rq2_wptr; // Write to Read Sync
    
    // Write Domain

    always @(posedge wclk or negedge wrst_n) begin
        if (!wrst_n) begin
            wptr_bin <= 0;
            wptr_gray <= 0;
        end else if (wen && !wfull) begin
            
            mem[wptr_bin[ADDR_WIDTH-1:0]] <= wdata;
            
            wptr_bin <= wptr_bin + 1;
            
            wptr_gray <= (wptr_bin + 1) ^ ((wptr_bin + 1) >> 1);
        end
    end
    
    // Read Domain
    always @(posedge rclk or negedge rrst_n) begin
        if (!rrst_n) begin
            rptr_bin <= 0;
            rptr_gray <= 0;
            rdata <= 0;
        end else if (ren && !rempty) begin
            // Read data from memory
            rdata <= mem[rptr_bin[ADDR_WIDTH-1:0]];
            
            // Increment binary pointer
            rptr_bin <= rptr_bin + 1;
            
            // Convert binary to Gray code
            rptr_gray <= (rptr_bin + 1) ^ ((rptr_bin + 1) >> 1);
        end
    end
    
    // Synch
    always @(posedge wclk or negedge wrst_n) begin
        if (!wrst_n) begin
            wq1_rptr <= 0;
            wq2_rptr <= 0;
        end else begin
            wq1_rptr <= rptr_gray;
            wq2_rptr <= wq1_rptr;
        end
    end
    

    always @(posedge rclk or negedge rrst_n) begin
        if (!rrst_n) begin
            rq1_wptr <= 0;
            rq2_wptr <= 0;
        end else begin
            rq1_wptr <= wptr_gray;
            rq2_wptr <= rq1_wptr;
        end
    end
    
    //Empty Flag
    assign rempty = (rptr_gray == rq2_wptr);
    
    // Full Flag, gray code to binary
    assign wfull = (wptr_gray == {~wq2_rptr[ADDR_WIDTH:ADDR_WIDTH-1], wq2_rptr[ADDR_WIDTH-2:0]});

endmodule
